{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/static/tauri/schema.json",
  "productName": "Bnot",
  "version": "0.1.10",
  "identifier": "com.bnot.app",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter web dev",
    "beforeBuildCommand": "pnpm --filter web build && pnpm --filter bnot-sidecar build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Bnot",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "width": 300,
        "height": 32,
        "x": 0,
        "y": 0
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["bnot"]
      }
    },
    "updater": {
      "endpoints": ["https://github.com/ababol/bnot/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3NDE0QjVBRkE3NTZBRDIKUldUU2FuWDZXa3RCTnhnNGprejUyaXIwZzlYRVgzOFY1c1FNdXR6Sm1BbEkwZGFtOEZyZno3VkMK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../../packages/sidecar/dist/index.mjs": "sidecar/index.mjs",
      "../../target/release/bnot-bridge": "bin/bnot-bridge"
    },
    "macOS": {
      "minimumSystemVersion": "14.0",
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
