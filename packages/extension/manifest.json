{
  "manifest_version": 3,
  "name": "Bnot - Open in Worktree",
  "version": "1.0.0",
  "description": "Adds 'Open in worktree' button to GitHub PR pages",
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
